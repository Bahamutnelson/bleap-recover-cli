# Copy to .env.test and fill with a real Bleap wallet on the source chain (Arbitrum).
# All values are PUBLIC (addresses / permission id / public RPC) — never put a private key here.
ARB_FORK_RPC=https://arb1.arbitrum.io/rpc
# A deployed Bleap Kernel-v3.1 wallet on Arbitrum with the cosigning module installed:
BLEAP_TEST_WALLET=0x...
# The wallet's ROOT permissionId, bytes32 left-aligned (4-byte id + 28 zero bytes):
BLEAP_TEST_PERMISSION_ID=0x...
# The address registered as signers[wallet][permissionId] (the wallet owner's key address):
BLEAP_TEST_OWNER=0x...
# A real deployWithFactory tx on the source chain whose `to` == the wallet factory (for wallet-deploy replay test):
BLEAP_TEST_WALLET_TX=0x...
# A target-chain RPC where BLEAP_TEST_WALLET is NOT yet deployed (code == 0x):
ETH_FORK_RPC=https://ethereum-rpc.publicnode.com
